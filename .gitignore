.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Vite
.vite/

# React / CRA
.cache/
coverage/

# Next.js
.next/

# Nuxt
.nuxt/

# Expo / React Native
.expo/
.expo-shared/
web-build/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
.nyc_output/

# Package manager caches
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Optional lock files if you do not want to commit them
# package-lock.json
# yarn.lock
# pnpm-lock.yaml